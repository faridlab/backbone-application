# syntax=docker/dockerfile:1.7
#
# Dev image for backbone-app. Source is bind-mounted at runtime by
# deployment/compose.dev.yaml — this image only carries the toolchain
# and cargo-watch so `cargo watch -x run` works inside the container.
#
# Production builds use the multi-stage release Dockerfile next door.

FROM rust:1.91-slim-bookworm

WORKDIR /app

# Same system deps the prod chef stage installs — required by
# backbone-* git deps (openssl, protobuf-compiler) and by cargo to
# fetch git crates over https.
RUN apt-get update && apt-get install -y --no-install-recommends \
      pkg-config \
      libssl-dev \
      ca-certificates \
      git \
      protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

RUN cargo install cargo-watch --locked --version ^8

# Warm the dep cache so the bind-mounted source's first `cargo run` doesn't
# re-clone every backbone-* git crate (~100+ crates, 2-3 min cold start).
# A stub `src/main.rs` is enough — `cargo fetch` only reads Cargo.toml /
# Cargo.lock to populate ~/.cargo/registry and ~/.cargo/git.
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs \
    && cargo fetch \
    && rm -rf src

ENV CARGO_TERM_COLOR=always

CMD ["cargo", "watch", "-x", "run --bin backbone-app"]
