# backbone-app — production runtime configuration.
#
# This file is the CONTRACT. Every uncommented var MUST be present and
# non-placeholder in `.env.prod` (the actual file with real secrets,
# gitignored). Commented-out vars are OPTIONAL — only uncomment if you
# intentionally enable that feature.
#
# Vars deliberately NOT in this file (and why):
#   - POSTGRES_USER/PASSWORD/DB         → in deployment/.env.prod (postgres container init)
#   - SMTP_HOST/PORT/USER/PASSWORD/etc  → in deployment/.env.prod (shared with Grafana)
#   - DATABASE_URL                      → constructed in deployment/compose.yaml
#   - REDIS_URL                         → set in deployment/compose.yaml
#   - MINIO_ENDPOINT                    → set in deployment/compose.yaml
#   - APP_NAME / APP_VERSION            → baked into binary by build.rs
#   - HOST / PORT / METRICS_PORT        → set explicitly in deployment/compose.yaml
#
# Usage:
#   cp .env.prod.example .env.prod
#   chmod 600 .env.prod
#   $EDITOR .env.prod                    # fill CHANGE_ME_* values
#   ./scripts/preflight-prod.sh          # validates the contract


# ═══════════════════════════════════════════════════════════════════════
# RUNTIME MODE & LOGGING
# ═══════════════════════════════════════════════════════════════════════

APP_ENV=prod
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/backbone-app
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10

# Trust proxy-supplied client IP headers (X-Forwarded-For / X-Real-IP).
# MUST be true when running behind Caddy (the prod topology). When false,
# the audit log and per-IP login throttle see the proxy's IP, not the
# real client. Only set to false if this service is exposed directly to
# clients without a trusted reverse proxy.
TRUST_PROXY_HEADERS=true

# Refuse to start when pending migrations exist. Belt-and-braces with the
# migrate one-shot in deployment/compose.yaml.
MIGRATIONS_STRICT=true

# Rust runtime knobs. RUST_BACKTRACE=1 logs stack traces on panic — turn
# off (=0) once the service is stable to avoid leaking internals in logs.
RUST_BACKTRACE=1
RUST_LOG=info,backbone_app=info,backbone=info


# ═══════════════════════════════════════════════════════════════════════
# AUTHENTICATION & ENCRYPTION
# ═══════════════════════════════════════════════════════════════════════

# JWT — minimum 32 chars for JWT_SECRET, ideally 64+ random bytes.
# Generate: `openssl rand -base64 64 | tr -d '\n'`
# Rotate on suspected exposure — invalidates ALL existing tokens.
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND
JWT_ALGORITHM=HS256
JWT_ISSUER=backbone-framework
JWT_AUDIENCE=backbone-users
JWT_EXPIRES_IN=24h
JWT_EXPIRY=86400
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt cost factor for password hashing. 12 = ~250ms per hash on modern
# hardware (good balance). 14 = ~1s, slower login but more brute-force resistant.
BCRYPT_ROUNDS=12

# CSRF token signing secret. Generate: `openssl rand -base64 32 | tr -d '\n'`
CSRF_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# Session cookie signing secret. Generate: `openssl rand -base64 32 | tr -d '\n'`
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# At-rest encryption key + IV (used by some modules to encrypt PII columns).
# ENCRYPTION_KEY: 32 bytes base64-encoded. Generate: `openssl rand -base64 32`
# ENCRYPTION_IV:  16 bytes base64-encoded. Generate: `openssl rand -base64 16`
# WARNING: rotating these without a re-encryption migration will brick
# encrypted data. Pick once, back up alongside the keystore.
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
ENCRYPTION_IV=CHANGE_ME_BASE64_16_BYTES


# ═══════════════════════════════════════════════════════════════════════
# MINIO (object storage — service-side credentials)
# ═══════════════════════════════════════════════════════════════════════

# Distinct from MINIO_ROOT_* in deployment/.env.prod (which provisions
# MinIO itself). These are a least-privilege user the service uses to
# read/write objects. On `docker compose up`, the `minio-init` job
# automatically creates this user and attaches an `app-svc` policy
# scoped to the two buckets — you only need to set the values here.
#
# Format: MinIO forbids `=` and `,` in access/secret keys. Generate with
# `tr -dc 'a-zA-Z0-9' </dev/urandom | head -c 20` (AK) and `head -c 40`
# (SK) — do NOT use base64 (its `=` padding is invalid).
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Storage backend selector. `minio` uses MinIO via S3 protocol;
# `filesystem` uses local disk (NOT recommended for prod — no replication).
STORAGE_TYPE=minio
STORAGE_PATH=/var/lib/backbone-app/storage

# Signing secret used to sign /cdn/<key> URLs that the service issues
# for short-lived public access. Generate: `openssl rand -base64 32`
BUCKET_LOCAL_SIGNING_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# Multipart upload body limits (MiB). Defaults match application.yml:
# 256 MiB single-shot, 16 MiB per chunk.
BUCKET_UPLOAD_SINGLE_SHOT_MB=256
BUCKET_UPLOAD_CHUNK_MB=16


# ═══════════════════════════════════════════════════════════════════════
# CORS & WEB CLIENTS
# ═══════════════════════════════════════════════════════════════════════

# Comma-separated list of allowed origins. Browsers enforce this for XHR
# / fetch from JS — the service rejects requests from origins not listed
# here. MUST include every production webapp domain.
CORS_ORIGIN=https://app.example.com


# ═══════════════════════════════════════════════════════════════════════
# RATE LIMITING & REQUEST HANDLING
# ═══════════════════════════════════════════════════════════════════════

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000             # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100             # per window per IP

# Hard request timeout (ms). Catches stuck handlers / runaway queries.
REQUEST_TIMEOUT=30000


# ═══════════════════════════════════════════════════════════════════════
# UPLOADS
# ═══════════════════════════════════════════════════════════════════════

MAX_FILE_SIZE=50MB
MAX_CONCURRENT_UPLOADS=10


# ═══════════════════════════════════════════════════════════════════════
# CACHING
# ═══════════════════════════════════════════════════════════════════════

ENABLE_CACHING=true
CACHE_PREFIX=backbone:prod:
CACHE_TTL=3600                          # seconds


# ═══════════════════════════════════════════════════════════════════════
# QUEUE / BACKGROUND WORK
# ═══════════════════════════════════════════════════════════════════════

# `redis` reuses the redis container; `rabbitmq` requires an optional
# rabbitmq service not in compose.yaml today. `memory` = in-process
# (lost on restart, dev-only).
QUEUE_TYPE=redis
# RABBITMQ_URL=amqp://...               # only if QUEUE_TYPE=rabbitmq

# Redis-backed queue uses a separate Redis logical DB to isolate queue
# state from the cache. The shared redis container handles both.
REDIS_QUEUE_HOST=redis
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=                   # blank = no auth (intra-network only)


# ═══════════════════════════════════════════════════════════════════════
# HEALTH CHECKS
# ═══════════════════════════════════════════════════════════════════════

HEALTH_CHECK_INTERVAL=30                # seconds between probes
HEALTH_CHECK_TIMEOUT=5                  # seconds before a probe is "failed"


# ═══════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════

METRICS_ENABLED=true
TRACING_ENABLED=false                   # turn on when you set up an OTLP collector
# JAEGER_ENDPOINT=http://jaeger:4317    # only if TRACING_ENABLED=true


# ═══════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════

ENABLE_AUDIT_LOGS=true                  # log every authn/CRUD action
ENABLE_API_VERSIONING=true              # /api/v1, /api/v2, etc.
ENABLE_MULTI_TENANCY=false              # turn on when launching multi-org

# Swagger UI. OFF in prod — exposing API docs publicly is a recon vector.
# Turn on temporarily during integration testing.
SWAGGER_ENABLED=false
SWAGGER_PATH=/api/docs

# GraphQL playground. Same reasoning — OFF in prod.
GRAPHQL_PLAYGROUND_ENABLED=false


# ═══════════════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS — uncomment + configure if/when enabled
# ═══════════════════════════════════════════════════════════════════════

# ─── Apple Push Notifications (iOS) ───────────────────────────────────
# APNS_KEY_ID=
# APNS_TEAM_ID=

# ─── Firebase Cloud Messaging (Android) ───────────────────────────────
# FCM_SERVER_KEY=

# ─── OAuth — Google ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Twilio (SMS / WhatsApp) ──────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
