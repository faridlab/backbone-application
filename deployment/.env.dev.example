# Local developer stack (compose.dev.yaml).
#
# Copy to .env.dev (gitignored) before first `docker compose up`.
# These values are NOT secrets — only used against the localhost stack.
# Never reuse them anywhere outside this machine.

# ─── Postgres ───────────────────────────────────────────────────────────
POSTGRES_USER=backbone
POSTGRES_PASSWORD=backbone-dev-pw
POSTGRES_DB=backbonedb

# ─── MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=backbone-admin
MINIO_ROOT_PASSWORD=backbone-dev-pw
MINIO_PRIVATE_BUCKET=backbone-private
MINIO_PUBLIC_BUCKET=backbone-public
# In dev, backbone-app uses the root creds against MinIO.
# In prod this is a least-privilege user provisioned via `mc admin user add`.
MINIO_ACCESS_KEY=backbone-admin
MINIO_SECRET_KEY=backbone-dev-pw

# ─── Security ───────────────────────────────────────────────────────────
# Dev-only secret. >=32 chars to satisfy the JWT module's validation.
JWT_SECRET=dev-only-jwt-secret-not-for-prod-32c
JWT_ALGORITHM=HS256
JWT_ISSUER=backbone-framework
JWT_AUDIENCE=backbone-users

# ─── Logging / runtime ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=text
APP_ENV=dev
RATE_LIMIT_ENABLED=false
