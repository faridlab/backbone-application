# backbone-app deployment — orchestration & infrastructure config.
#
# Scope: this file holds ONLY values needed by the deployment stack
# itself (image tags, infra container init, edge config, alerting).
# Service runtime config (JWT, MinIO access creds, log level, rate
# limiting) lives in the repo-root `.env.prod` (see `.env.prod.example`
# at the project root for the contract).
#
# Copy to .env.prod on the VPS (chmod 600). NEVER commit the real file.
#
# All vars below are validated by `docker compose` itself via ${VAR:?...}
# substitution in compose.yaml — empty/unset → deploy aborts with a
# clear error pointing at the missing var.
#
# Run `./scripts/preflight-prod.sh` from the repo root before any deploy
# to validate locally without leaving your laptop.

# ─── Edge / TLS ─────────────────────────────────────────────────────────
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# ─── Image registry ─────────────────────────────────────────────────────
# GitHub org / user that hosts the GHCR image. The compose stack references
# ghcr.io/${GHCR_OWNER}/backbone-app:${SERVICE_TAG}.
GHCR_OWNER=your-github-org

# ─── Image tags (REQUIRED — `docker compose up` errors out if any unset) ──
# Pin each to a specific version that exists in GHCR. CI pushes versions
# on `git tag v*` push (see .github/workflows/release-image.yml). Examples:
#   SERVICE_TAG=v0.5.2          ← from CI
# Do NOT use moving tags (`latest`, `beta`) in prod — accidentally changes
# what's running. Roll back by flipping the value to a prior version.
SERVICE_TAG=

# ─── Postgres (container init + DATABASE_URL substitution) ────────────
# Used both by the postgres container to initialize the DB AND by compose
# to construct the DATABASE_URL passed to backbone-app. Same value in two
# places — keep them as one source of truth here.
POSTGRES_USER=backbone
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING
POSTGRES_DB=backbone

# ─── MinIO (container admin creds + bucket bootstrap) ─────────────────
# These are the MinIO container's ROOT creds (used by `mc admin` ops and
# the minio-init bootstrap). The service uses a separate, lower-privilege
# pair (MINIO_ACCESS_KEY / MINIO_SECRET_KEY) defined in the repo-root
# .env.prod — see that file's `.env.prod.example`.
MINIO_ROOT_USER=backbone-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING
MINIO_PRIVATE_BUCKET=backbone-private
MINIO_PUBLIC_BUCKET=backbone-public

# ─── Grafana (dashboards + alerting) ──────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_SMTP_ENABLED=true

# ─── SMTP (shared by Grafana alerts AND backbone-app transactional) ──
# The mailbox/SMTP server is shared infrastructure, so creds live here
# (not in the service's .env.prod). Both the grafana container and the
# backbone-app container read these via env_file.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Backbone
